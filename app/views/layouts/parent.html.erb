<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-controller="theme" <%= tag.attributes(theme_attributes) %>>
  <head>
    <title><%= content_for(:title) || t("app.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="view-transition" content="same-origin">
    <meta name="color-scheme" content="light dark">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <% if Current.user.admin? %>
      <meta name="turbo-cache-control" content="no-cache">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= render "appkit/shared/pwa_meta" %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "mvpa/mvpa", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <nav data-controller="nav" data-action="click->nav#click">
        <h2><%= t("app.title") %></h2>
        <ul>
          <% if Current.user.admin? %>
            <li><%= link_to t("admin.nav.dashboard"), admin_root_path, "aria-current": (current_page?(admin_root_path) ? "page" : nil) %></li>
            <li><%= link_to t("admin.nav.users"), admin_users_path, "aria-current": (request.path.start_with?("/admin/users") ? "page" : nil) %></li>
            <li><%= link_to t("admin.nav.back_to_site"), root_path %></li>
          <% end %>
          <li><%= link_to t("navigation.preferences"), edit_preferences_path %></li>
          <li><%= button_to t("common.logout"), session_path, method: :delete %></li>
        </ul>
      </nav>
    </header>
    <%= render "appkit/shared/flashes" %>
    <%= yield %>
    <fieldset data-controller="push">
      <button type="button" data-action="push#subscribe"><%= t("parent.push.enable") %></button>
    </fieldset>
    <footer>
      <p><%= t("footer.copyright", year: Date.current.year, app_name: t("app.title")) %></p>
    </footer>
  </body>
</html>
