<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-controller="theme" <%= tag.attributes(theme_attributes) %>>
  <head>
    <title><%= content_for(:title) || t("app.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="view-transition" content="same-origin">
    <meta name="color-scheme" content="light dark">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= render "appkit/shared/pwa_meta" %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "mvpa/mvpa", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <nav data-controller="nav" data-action="click->nav#click">
        <h2><%= t("app.title") %></h2>
        <ul>
          <li><%= link_to t("child.dashboard.profile_link"), edit_user_profile_path(Current.user) %></li>
          <li><%= link_to t("navigation.preferences"), edit_preferences_path %></li>
          <li><%= button_to t("common.logout"), session_path, method: :delete %></li>
        </ul>
      </nav>
    </header>
    <%= render "appkit/shared/flashes" %>
    <%= yield %>
    <footer>
      <p><%= t("footer.copyright", year: Date.current.year, app_name: t("app.title")) %></p>
    </footer>
  </body>
</html>
