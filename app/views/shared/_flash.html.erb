<% if flash.any? %>
  <section aria-label="<%= t("flash.notifications") %>" data-mvpa-flashes>
    <% flash.each do |type, message| %>
      <aside role="<%= type == 'notice' ? 'status' : 'alert' %>" data-controller="fade-out">
        <%= message %>
      </aside>
    <% end %>
  </section>
<% end %>
