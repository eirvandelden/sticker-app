<main>
  <header>
    <h1><%= t("parent.dashboard.title") %></h1>
    <nav>
      <% if Current.user.admin? %>
        <%= link_to t("navigation.admin"), admin_root_path %>
      <% end %>
      <%= link_to t("navigation.preferences"), edit_preferences_path %>
      <%= button_to t("common.logout"), session_path, method: :delete %>
    </nav>
  </header>

  <% if @open_cards_count.to_i > 0 %>
    <article role="alert">
      <p><strong><%= t("parent.dashboard.open_cards", count: @open_cards_count) %></strong></p>
    </article>
  <% end %>

  <% @children.each do |child| %>
    <article data-controller="confetti"
             data-confetti-completion-flag-id-value="<%= dom_id(child, :completion_flag) %>">
      <header>
        <% if child.user.avatar.attached? %>
          <%= image_tag child.user.avatar, size: "40x40", alt: child.user.name %>
        <% end %>
        <h2><%= child.user.name %></h2>
        <nav>
          <%= link_to t("parent.children.index.edit_name"), edit_parent_child_path(child) %>
          <%= link_to t("parent.children.index.edit_avatar"), edit_parent_child_avatar_path(child) %>
          <%= link_to t("parent.child_profile.edit.title"), edit_parent_child_child_profile_path(child) %>
        </nav>
      </header>

      <%= turbo_stream_from child %>

      <span id="<%= dom_id(child, :completion_flag) %>"></span>

      <%= render "parent/children/child_card", child: child %>

      <footer>
        <%= button_to t("parent.actions.give_sticker"), parent_child_sticker_path(child),
                      method: :post,
                      params: { emoji_mode: "random" },
                      class: "button-success" %>

        <%= button_to t("parent.actions.give_penalty"), parent_child_penalty_path(child),
                      method: :post,
                      class: "button-danger" %>

        <%= link_to t("parent.actions.view_history"), parent_child_history_path(child) %>
      </footer>
    </article>
  <% end %>

</main>
