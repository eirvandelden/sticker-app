<main data-controller="confetti"
      data-confetti-completion-flag-id-value="<%= dom_id(@child_profile, :completion_flag) %>">
  <header>
    <h1><%= t("child.dashboard.title") %></h1>
    <nav>
      <%= link_to t("child.dashboard.profile_link"), edit_user_profile_path(Current.user) %>
      <%= link_to t("navigation.preferences"), edit_preferences_path %>
      <%= button_to t("common.logout"), session_path, method: :delete %>
    </nav>
  </header>

  <article>
    <%= turbo_stream_from @child_profile %>

    <span id="<%= dom_id(@child_profile, :completion_flag) %>"></span>

    <section id="<%= dom_id(@child_profile, :notifications) %>">
      <% @recent_stickers.each do |s| %>
        <%= render "child/dashboard/sticker_notification", sticker: s %>
      <% end %>
    </section>

    <%= render "child/dashboard/card", child_profile: @child_profile, last_viewed: @last_viewed %>
  </article>

</main>
